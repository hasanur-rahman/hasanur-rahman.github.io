author = {Rahman, Md Hasanur and Shamji, Aabid and Guo, Shengjian and Li, Guanpeng},
title = {PEPPA-X: Finding Program Test Inputs to Bound Silent Data Corruption Vulnerability in HPC Applications},
year = {2021},
